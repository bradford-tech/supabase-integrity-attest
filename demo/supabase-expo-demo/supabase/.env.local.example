# =============================================================================
# Supabase Edge Function Environment Variables
# =============================================================================
# Copy this file to .env.local in this same directory (supabase/.env.local).
# .env.local is gitignored by Supabase CLI's default .gitignore.
#
# These env vars are available to edge functions via Deno.env.get().
# Supabase CLI injects them on `supabase start` / `supabase functions serve`.
# =============================================================================

# ---------------------------------------------------------------------------
# Apple App Attest identity (must match the client-side values)
# ---------------------------------------------------------------------------
# Format: TEAMID.bundleIdentifier
# Example: ABC123DEF4.com.example.myapp
#
# This must match EXPO_PUBLIC_TEAM_ID + "." + EXPO_PUBLIC_BUNDLE_IDENTIFIER
# from the Expo client's .env.local. If these don't match, the library's
# verifyAttestation / verifyAssertion will reject with RP_ID_MISMATCH.
#
# If unset, defaults to "TEAMID1234.com.example.demo" in non-production
# environments (for the Phase B integration test). In production, the
# server will throw if APP_ID is missing.
APP_ID=

# Set to "production" for production AAGUID. Any other value (or unset)
# uses the development AAGUID.
# ENVIRONMENT=development
