# =============================================================================
# Expo Client Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in your values.
# .env.local is gitignored by Expo's default .gitignore.
#
# These EXPO_PUBLIC_* vars are inlined by Metro at bundle time — changes
# require restarting the Metro bundler (Ctrl+C → npx expo run:ios).
# =============================================================================

# ---------------------------------------------------------------------------
# Supabase connection
# ---------------------------------------------------------------------------
# Your host machine's LAN IP so the iPhone can reach supabase start.
# Find it via: ipconfig getifaddr en0 (macOS)
# Do NOT use 127.0.0.1 or localhost — the iPhone can't reach those.
# Simulator can use localhost (it's the default fallback when unset).
EXPO_PUBLIC_SUPABASE_URL=http://192.168.x.x:54321

# ---------------------------------------------------------------------------
# Apple App Attest identity
# ---------------------------------------------------------------------------
# Your 10-character Apple Team ID. Find it at:
# https://developer.apple.com/account → Membership details → Team ID
EXPO_PUBLIC_TEAM_ID=

# Your app's bundle identifier in reverse-DNS format (e.g., com.example.myapp).
# This must match an App ID registered in the Apple Developer portal with
# the App Attest capability EXPLICITLY ENABLED:
#
#   1. Go to https://developer.apple.com/account/resources/identifiers
#   2. Select (or create) your App ID
#   3. Under Capabilities, check "App Attest"
#   4. Save — this regenerates the provisioning profile
#   5. In Xcode: Signing & Capabilities → re-download the profile
#
# WITHOUT App Attest enabled, attestation will fail with RP_ID_MISMATCH
# and there is no workaround.
EXPO_PUBLIC_BUNDLE_IDENTIFIER=
