{
  "name": "docs",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "node scripts/generate-diagrams.mjs && next build --webpack",
    "check": "prettier --check . --log-level warn && eslint . && tsc --noEmit",
    "dev": "next dev --webpack",
    "fix": "prettier --write . --log-level warn && eslint --fix . && tsc --noEmit",
    "generate-diagrams": "node scripts/generate-diagrams.mjs",
    "lint": "eslint .",
    "start": "next start"
  },
  "browserslist": "defaults, not ie <= 11",
  "overrides": {
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3"
  },
  "dependencies": {
    "@algolia/autocomplete-core": "^1.19.2",
    "@headlessui/react": "^2.2.6",
    "@markdoc/markdoc": "^0.5.4",
    "@markdoc/next.js": "^0.5.0",
    "@sindresorhus/slugify": "^2.2.1",
    "@tailwindcss/postcss": "^4.2.0",
    "@tailwindcss/typography": "^0.5.16",
    "@types/react-highlight-words": "^0.20.0",
    "clsx": "^2.1.1",
    "fast-glob": "^3.3.3",
    "flexsearch": "^0.8.205",
    "js-yaml": "^4.1.0",
    "next": "16.1.6",
    "next-themes": "^0.4.6",
    "prism-react-renderer": "^2.4.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-highlight-words": "^0.21.0",
    "simple-functional-loader": "^1.2.1",
    "tailwindcss": "^4.2.0"
  },
  "devDependencies": {
    "@terrastruct/d2": "^0.1.33",
    "@types/node": "^24.1.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "eslint": "^9.32.0",
    "eslint-config-next": "16.1.6",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "sharp": "0.34.5"
  }
}
