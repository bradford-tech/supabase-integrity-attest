{
  "$schema": "https://turborepo.dev/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", "!README.md", "!CHANGELOG.md"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "check": {
      "dependsOn": ["^check"],
      "inputs": ["$TURBO_DEFAULT$", "!README.md", "!CHANGELOG.md"]
    },
    "format": {
      "cache": false
    },
    "fix": {
      "cache": false
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "interruptible": true
    },
    "lint": {
      "inputs": ["$TURBO_DEFAULT$", "!README.md", "!CHANGELOG.md"]
    },
    "test": {
      "inputs": ["$TURBO_DEFAULT$", "!README.md", "!CHANGELOG.md"]
    }
  }
}
